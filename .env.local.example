# ---------------------------------------------------------------------------
# Harvesters Finance OS — Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` (git-ignored) for local development, and set
# the equivalent values in your hosting provider (e.g. Vercel) for production.
#
# Phase 0 wires the Supabase client only; no schema or data access exists yet.
# ---------------------------------------------------------------------------

# Supabase project URL (Project Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase publishable/anon key — safe for the browser (RLS-protected)
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Supabase service-role key — SERVER ONLY. Never expose to the browser and
# never prefix with NEXT_PUBLIC_. Bypasses RLS; use only in trusted server code.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# Public site URL (used for auth redirects, absolute links)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
